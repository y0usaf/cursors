{
  "name": "deepin-minimal-svg-design-system",
  "description": "Minimal Google_Cursor-style SVG token system. Source SVGs use exact sentinel colours; render.sh swaps them into shell-defined palettes.",
  "source_dir": "src",
  "output_dir": "themes/<palette>/svg",
  "tokens": {
    "base": {
      "source": "#00ff00",
      "from": [
        "implicit/default black fill",
        "#000",
        "#000000",
        "#111"
      ],
      "role": "main cursor body / former black"
    },
    "outline": {
      "source": "#0000ff",
      "from": [
        "#fff",
        "#ffffff"
      ],
      "role": "contrast outline / former white"
    },
    "danger": {
      "source": "#fa1919",
      "from": [
        "#fa1919"
      ],
      "role": "no-drop / not-allowed / pirate red accent"
    },
    "action": {
      "source": "#1e82ff",
      "from": [
        "#1e82ff"
      ],
      "role": "alias/context-menu action badge"
    },
    "busy_base": {
      "source": "#025ee8",
      "from": [
        "#025ee8"
      ],
      "role": "wait/progress dark blue"
    },
    "busy_highlight": {
      "source": "#2ca7f8",
      "from": [
        "#2ca7f8"
      ],
      "role": "wait/progress light blue"
    },
    "success": {
      "source": "#32aa32",
      "from": [
        "#32aa32"
      ],
      "role": "copy success badge"
    },
    "warning": {
      "source": "#ffc800",
      "from": [
        "#ffc800"
      ],
      "role": "help warning badge"
    },
    "orange": {
      "source": "#f67400",
      "from": [
        "#f67400"
      ],
      "role": "wayland/x-cursor orange accent"
    }
  },
  "palettes": {
    "black-inner-white-outer": {
      "base": "#000000",
      "outline": "#ffffff",
      "danger": "#fa1919",
      "action": "#1e82ff",
      "busy_base": "#025ee8",
      "busy_highlight": "#2ca7f8",
      "success": "#32aa32",
      "warning": "#ffc800",
      "orange": "#f67400"
    },
    "white-inner-black-outer": {
      "base": "#ffffff",
      "outline": "#000000",
      "danger": "#fa1919",
      "action": "#1e82ff",
      "busy_base": "#025ee8",
      "busy_highlight": "#2ca7f8",
      "success": "#32aa32",
      "warning": "#ffc800",
      "orange": "#f67400"
    },
    "red-inner-white-outer": {
      "base": "#ff0000",
      "outline": "#ffffff",
      "danger": "#ff0000",
      "action": "#1e82ff",
      "busy_base": "#025ee8",
      "busy_highlight": "#2ca7f8",
      "success": "#32aa32",
      "warning": "#ffc800",
      "orange": "#f67400"
    },
    "pastel-blue-inner-black-outer": {
      "base": "#a7c7e7",
      "outline": "#000000",
      "danger": "#e84f68",
      "action": "#4aa3ff",
      "busy_base": "#3d7dd8",
      "busy_highlight": "#89d6ff",
      "success": "#76c893",
      "warning": "#ffd166",
      "orange": "#f4a261"
    }
  },
  "notes": [
    "base is the cursor inner/body colour (former black/default fill, source #00ff00).",
    "outline is the cursor outer/contrast colour (former white fill/stroke, source #0000ff).",
    "Semantic accent colours are exact-value tokens and can be adjusted per palette.",
    "Rendering is dependency-free shell + sed; no Python/Node/npm required."
  ]
}
